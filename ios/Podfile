# Uncomment this line to define a global platform for your project
platform :ios, '14.0'

# Silence all warnings from pods
inhibit_all_warnings!

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # This is just a temporary solution to fix the iOS build issue. We need to remove this line after the author fixes this [issue](https://github.com/natintosh/plugin_libphonenumber/issues/35)
  pod 'PhoneNumberKit', '3.8.0'

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings["EXCLUDED_ARCHS[sdk=iphonesimulator*]"] = "arm64 i386"

      ## Fix issue "Error 'DT_TOOLCHAIN_DIR" - https://github.com/CocoaPods/CocoaPods/issues/12012#issuecomment-1653051943
      if config.base_configuration_reference
        xcconfig_path = config.base_configuration_reference.real_path
        xcconfig = File.read(xcconfig_path)
        xcconfig_mod = xcconfig.gsub(/DT_TOOLCHAIN_DIR/, "TOOLCHAIN_DIR")
        # Remove the -G flag (and -G<n> variants like -G0, -G8) from xcconfig files.
        # This flag is injected by some pods (e.g. google_mobile_ads) but is unsupported
        # by Clang for arm64-apple-ios targets, causing "unsupported option '-G'" errors.
        xcconfig_mod = xcconfig_mod.gsub(/\s-G\d*(?=\s|$)/, '')
        File.open(xcconfig_path, "w") { |file| file << xcconfig_mod }
      end

      ## Aggressively suppress ALL warnings to prevent Codemagic log truncation
      config.build_settings['WARNING_CFLAGS'] = ['-w']
      config.build_settings['GCC_WARN_INHIBIT_ALL_WARNINGS'] = 'YES'
      config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
      config.build_settings['CLANG_WARN_DOCUMENTATION_COMMENTS'] = 'NO'
      config.build_settings['RUN_CLANG_STATIC_ANALYZER'] = 'NO'
      config.build_settings['COMPILER_INDEX_STORE_ENABLE'] = 'NO'

      ## Fix: Remove invalid '-G' flag injected by some pods (e.g. google_mobile_ads Metal shaders)
      ## '-G' is a CUDA/GPU compiler option not supported by Clang for arm64-apple-ios targets
      ['OTHER_CFLAGS', 'OTHER_CPPFLAGS'].each do |flags_key|
        flags = config.build_settings[flags_key]
        if flags.is_a?(Array)
          config.build_settings[flags_key] = flags.reject { |f| f.strip == '-G' }
        elsif flags.is_a?(String)
          config.build_settings[flags_key] = flags.gsub(/\s*-G\s*/, ' ').strip
        end
      end

      ## permission handler
      if target.name == 'permission_handler_apple'
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
          '$(inherited)',

          ## dart: PermissionGroup.camera
          'PERMISSION_CAMERA=1',

          ## dart: PermissionGroup.photos
          'PERMISSION_PHOTOS=1'
        ]
      else
        config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
          '$(inherited)',
          'AUDIO_SESSION_MICROPHONE=0'
        ]
      end
    end
  end

  # Fix for Xcode 15 and Firebase 8/9 C++ compilation issue
  firestore_settings = File.join(installer.sandbox.root, 'FirebaseFirestore', 'Firestore', 'Source', 'API', 'FIRFirestoreSettings.mm')
  if File.exist?(firestore_settings)
    content = File.read(firestore_settings)
    content = content.gsub(/ABSL_CONST_INIT extern "C"/, 'extern "C"')
    File.write(firestore_settings, content)
  end
end

target 'OneSignalNotificationServiceExtension' do
  use_frameworks!
  pod 'OneSignalXCFramework', '>= 5.0.0', '< 6.0'
end

# Fixes Flutter.framework in shell script build phase '[CP] Embed Pods Frameworks' error
install! 'cocoapods', :disable_input_output_paths => true
